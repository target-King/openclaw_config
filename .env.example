# =========================
# Environment Example
# Copy this file to .env if needed
# Do NOT commit your real .env
# =========================

APP_ENV=dev

# Optional: override target OpenClaw home path
# OPENCLAW_HOME=C:\Users\YourName\.openclaw

# Optional: current project name
PROJECT_NAME=openclaw-home

# Memory database path
MEMORY_DB_PATH=data/memory.db

# Future expansion placeholders
OPENCLAW_API_BASE=
OPENCLAW_API_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
